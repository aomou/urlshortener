# Djagno 設定
SECRET_KEY=xxx
DEBUG=True
DJANGO_SUPERUSER_PASSWORD=password
RENDER_EXTERNAL_HOSTNAME=your-app.onrender.com

# Database 設定
# 使用 127.0.0.1 而非 localhost 以確保 OAuth 回調的可靠性
DATABASE_URL=postgres://user:password@127.0.0.1:5432/dbname

# OAuth 設定
# 重要：在 Google 開發者控制台設定回調 URL 時，請使用 http://127.0.0.1:8000
# 而非 http://localhost:8000 以避免 DNS 解析問題

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_SECRET_KEY=your-google-client-secret

