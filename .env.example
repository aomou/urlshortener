# Django 設定
SECRET_KEY=
DEBUG=True         # 本機 dev: True；生產: False
# 只在 Docker 部署 / CI 用 createsuperuser --noinput 時才需要
DJANGO_SUPERUSER_PASSWORD=

# 部署網域（VPS + Cloudflare）。例如 example.com，本機開發留空即可
SITE_DOMAIN=

# Database 設定
DB_NAME=url_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost      # 本機 dev: localhost；Docker: db（compose service name）
DB_PORT=5432

# Google OAuth
# 本機 dev: callback URL 設 http://127.0.0.1:8000/accounts/google/login/callback/
#           （不要用 localhost，某些系統 DNS 解析會出包）
# 生產環境: callback URL 設 https://<SITE_DOMAIN>/accounts/google/login/callback/
#           建議申請另一組 Client ID/Secret，跟本機 dev 那組分開
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
