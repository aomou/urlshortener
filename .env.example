# Django 設定
SECRET_KEY=
DEBUG=False
DJANGO_SUPERUSER_PASSWORD=
# 部署網域（VPS + Cloudflare）。例如 example.com，本機開發留空即可
SITE_DOMAIN=

# Database 設定
DB_NAME=url_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# OAuth 設定
# 重要：在 Google 開發者控制台設定回調 URL 時，請使用 http://127.0.0.1:8000
# 而非 http://localhost:8000 以避免 DNS 解析問題

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

